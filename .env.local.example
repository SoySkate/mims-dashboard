# Copy to .env.local and fill in. NEVER commit real secrets (.env.local is git-ignored).

# Local dev Postgres (Docker, see docker-compose.yml). In prod this points at the real DB.
DATABASE_URL=postgres://mims:mims_dev_pw@localhost:5433/mims_dashboard_dev

# Secret for signing session JWTs (jose). Generate: openssl rand -base64 32
SESSION_SECRET=

# Chatwoot (server-side only; super-admin api_access_token — never expose to the browser)
CHATWOOT_BASE_URL=https://inbox.mims.studio
CHATWOOT_TOKEN=

# n8n "Motor de reservas" webhook (server-side only). Create-reserva writes go through it
# so the Motor validates capacity/overlap/hours and writes Postgres itself.
N8N_MOTOR_URL=
# Optional bearer token (the webhook is open for now). If set, it is sent as Authorization: Bearer.
N8N_MOTOR_TOKEN=
